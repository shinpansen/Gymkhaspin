config_version=5

[application]

config/name="Gymkhaspin"
run/main_scene="uid://dvxex3qbkk2i0"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SkidMarksFactory="*uid://c04343lklhxoj"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[file_customization]

folder_colors={
"res://assets/": "pink",
"res://scenes/": "yellow",
"res://scripts/": "purple"
}

